{
  "name": "bettercr",
  "version": "1.13.1",
  "private": true,
  "description": "BetterCR — extension Chrome qui refond l'UI de Crunchyroll avec l'API officielle, sans backend.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:only": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint:fix": "eslint . --fix && prettier --write \"src/**/*.{ts,tsx,css}\"",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.2.0",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.4.3"
  }
}
